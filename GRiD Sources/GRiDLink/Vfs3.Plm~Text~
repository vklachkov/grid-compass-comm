/*&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&
&
&	This is VFS3.  
&
&	PROCEDURES:
&		All the server code assumes single IPC connection to VfsManager
&
&		Called from EntryPoint:
&
&			VfsInitialize
&			VfsTerminate
&			VfsSignon
&			VfsSignOff
&			FsChangeUserContext
&
&		Called from Vfs1/2:
&
&			GetVipcConnID
&			GiveUpVipcConnID
&			VipcInternalSend
&
&		Called from Vipc2:
&
&			VfsResetVipcConnForDevice
&
&		NOOPS for server Vfs
&
&	Author:	Rajendra Shah
&	Start Date:	12/13/82
&
&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&*/
 
/*&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&
&	some history:
&
&	In the old scheme multiple VIPC connections were used to send file
&	system request.  A VIPC connection was used for every logical device in
&	the ADT.  For device not in the ADT, a new Vipc connection was used
&	for every file attached on that device.
&
&	In the new scheme only one VIPC conn is maintained between Vfs and 
&	Vfs~manager~ and all file system requests are sent on that connection.  
&	The old code is removed.  Look at archive if necessary.
&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&*/


