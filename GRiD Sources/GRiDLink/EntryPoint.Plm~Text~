$IF serverVfs OR PostOffice
DCL sVfsLayerConnCB	SELECTOR EXTERNAL;
$ENDIF

DCL dummyError  WORD,
	dummyNote	WORD AT (@dummyError),
	dummyW		WORD AT (@dummyError);

  	
	/* This variable counts the number of times this driver is activated so that
	when it starts getting deactivates, it can ignore them until the last
	deactivate */

DCL activated	 BOOLEAN INITIAL (FALSE);

$IF notused
DCL CopyrightMsg (*) BYTE DATA ('Copyright (c) 1982,1983,1984,1985',cr,lf,
								'GRiD Systems Corporation');
$ENDIF

/*&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&
&					WMin
&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&*/

WMin: PROCEDURE (a, b) WORD CLEAN;
	DCL (a, b) WORD;
	IF a < b THEN RETURN a;
	ELSE RETURN b;
END WMin;

$EJECT
/*&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&
&				Virtual File System 
&						and 
&		Virtual Inter-Process Communication 
&					EntryPoint
&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&*/

EntryPoint: PROCEDURE (request, pPl, pError) CLEAN;
	DCL request		WORD;

	DCL pPl			PTR,
		pl			BASED pPl	ParamListType;

	DCL pError		PTR,
		error		BASED pError WORD;

	DCL pBuffer		PTR;
	DCL pPassword	PTR;
	DCL length		WORD;
	DCL numbuf		BYTE;	/* also access */
	DCL mode		BYTE;

	DCL	sConnCB		SELECTOR,
		connID		WORD AT (@sConnCB),
		vfsConnCB	BASED sConnCB VfsConnCBType,
		vipcConnCB	BASED sConnCB VipcConnCBType;

	sConnCB = pl.connection;
	pBuffer	= pl.pBuffer;
	pPassword = pl.pOverflow;
	length	= pl.length;
	numBuf	= pl.numbuf;			/* also used for access */
	mode	= pl.mode;
	error = 0;	

$IF serverVFS OR PostOffice
	IF request = ddChangeUserContext THEN sConnCB = sVfsLayerConnCB;
$ENDIF

$IF Debugging
	IF DetailedFsMaskSet THEN
		DO;
		DCL msg CHarStr ('     ',cr,lf,'Request/Conn/ConnType:');
		CALL ConLineout (@msg, size (msg));
		CALL Hexout (request);
		CALL HexOut (connID);
		IF vfsConnCB.connType = 0 THEN CALL ConLineOUT (@(' VFS'), 4);
		ELSE IF vfsConnCB.connType = 1 THEN CALL ConLineOUT (@(' VIPC'), 5);
		ELSE CALL HexByteOut (vfsCOnnCB.connType);
		CALL newline;
		END;
$ENDIF

$EJECT
	IF request = ddInitialize THEN 
		DO;
		IF NOT activated THEN 
			DO;
$IF Debugging
			DCL GetDebugMask BOOLEAN;
$ENDIF
$IF (NOT MsDos) AND (NOT serverVFS) AND (NOT Phonelink)
			CALL FigureOutSystem;
$ENDIF
$IF Debugging 
			IF mode = 0FEh THEN GetDebugMask = TRUE;
			ELSE IF ConKeyPressed THEN
				DO;
				DCL ch BYTE;
				ch = ConCharIn;
				IF ch = 'd' OR ch = 'D' THEN GetDebugMask = TRUE;
				ELSE GetDebugMask = FALSE;
				END;
			ELSE GetDebugMask = FALSE;

			IF GetDebugMask THEN 
				DO;
				DCL pipelineMsg CharStr ('Enter pipeline size (default is 1):');
				DCL LongReadMsg CharStr 
						('This version implements long reads',cr,lf);
				DCL DelayMsg CharStr 
						('Enter extra turnaround delay reqd (in ms):');

				CALL ConLineOut (@DbgMasks, size (dbgMasks));
				DebugMask = ConHexIn;		   
    			CALL InitTiming;

$				IF pipelinedRead
					CALL ConLineOut (@pipelineMsg, size(pipelineMsg));
					pipeLineSize = ConHexIn;
					IF pipeLineSize = 0 THEN pipeLineSize = 1;
$				ELSEIF LongRead
					CALL ConLineOut (@LongReadMsg, size(LongReadMsg));
$				ENDIF
				END;
$ENDIF			
			error = VfsInitialize;
			activated = TRUE;
			END;
		END;

	ELSE IF request = ddDeactivate THEN
	 	DO;
$IF Debugging
		IF (debugMask AND Dbits_MajorEvents) <> 0 THEN
			CALL ConLineOut (@('Deactivate',cr,lf),12);
$ENDIF
		IF activated THEN
		 	DO;
			error = VfsTerminate;
			IF error = 0 THEN activated = false;
			END;
		END;

$IF Debugging
	ELSE IF request = ddSetDebugMask THEN
		DO;
		DCL msg CharStr ('Current Debug Mask Is: ');
		CALl ConLineOUt (@msg, size (msg));
		CALL ConHexOut (debugMask);
		CALL ConLineOut (@DbgMasks, size (dbgMasks));
		DebugMask = ConHexIn;
    	CALL InitTiming;			/* Useful if timing mask is set */
		END;
$ENDIF

$IF NOT serverVfs
	ELSE IF request = ddReadDlcCounters 
		THEN CALL DlcReadCounters (@pl.Length, pBuffer);

	ELSE IF request = ddGetUserInfo
		THEN error = VipcGetUserInfo (@pl.Length, pBuffer);

	ELSE IF request = ddGetLinkStatus
		THEN error = VipcGetLinkStatus (@pl.Length, pBuffer);
$ENDIF

	ELSE IF request = ddSignon 
		THEN error = VfsSignon (@pl.Length, pBuffer, pPassword);

	ELSE IF request = ddSignoff THEN 
		DO;
$IF MsDos
		CALL ResetInterceptor;
$ENDIF
		error = VfsSignOff;
		END;

$IF MsDos
	ELSE IF request = ddAddVfsDevice 
		THEN error = AddVfsDevice (pBuffer, length);

	ELSE IF request = ddGetVfsDevice THEN pL.pBuffer = GetVfsDevice (numbuf);

	ELSE IF request = ddSetServerName THEN CALL SetServername (pBuffer);

	ELSE IF request = ddGetServerName THEN pL.pBuffer = GetServerName;

	ELSE IF request = ddGetPrinterAlias THEN pL.pBuffer = GetPrinterAlias;

	ELSE IF request = ddSetPrinterAlias 
		THEN error = SetPrinterAlias (mode, pBuffer);

	ELSE IF request = ddRestoreInterrupts
		THEN pl.pBuffer = MsRestoreInterrupts (@error);
	
$ENDIF

$EJECT
	ELSE IF request = ddAttach THEN 
	  	DO;
$IF NOT serverVFS
		IF mode = ProcessConnectMode THEN 
    		DO;
			vipcConnCB.connType = VipcConnection;
			vipcConnCB.clientIsVfs = FALSE;
			error = VipcConnect (sConnCB, pBuffer);
			END;
		
		ELSE
$ENDIF
	  		error = FsAttach (sConnCB, mode, numbuf, pBuffer, pPassword);
		END;
			
	ELSE 
		DO;
		/* For the following requests, Wait on in-use semaphore. 
		At most one outstanding request will be permitted per 
		connection.  Hence all calls except Attach are blocked
		by the inUse semaphore. Attach of course creates this 
		semaphore and detach deletes it. */

		/* The inUseSemaphore field is common to VfsConnCB & VIPCCOnnCB */

$IF Debugging
		dummyNote = OsWait (vfsConnCB.inUseSema, 0, @error);
		IF error = eTimeout THEN
			DO;
			DCL msg CharStr ('Waiting for inUseSema for Conn = ');
			CALL ConLineOUt (@msg, size (msg));
			CALL ConHexOut (connID);
			CALL newline;
			error = 0;
			dummyNote = OsWait (vfsConnCB.inUseSema, 0fffffh, @dummyError);
			END;
$ELSE
		dummyNote = OsWait (vfsConnCB.inUseSema, 0fffffh, @dummyError);
$ENDIF

	
$IF NOT serverVFS
		IF (vfsConnCB.connType = VipcConnection) THEN
			DO;	/* IPC requests */
			IF request = ddDetach THEN error = VipcDisconnect (sConnCB);
			ELSE IF request = ddSend 
				THEN error = VipcSend (ConnID, LOW (pl.position), 
	        					HIGH (pl.position), pBuffer);
			ELSE IF request = ddSetStatus 
				THEN error = VipcSetStatus (sConnCB, pBuffer, length);
			ELSE error = eNotSupport;
			END;

$EJECT
		ELSE
$ENDIF
			DO;		/* VFS requests */
			IF request = ddRemoteCopy 
		    	THEN error = FsRemoteCopy (sConnCB, pBuffer);

			ELSE IF request = ddSetStatus 
		    	THEN error = FsSetStatus (sConnCB, pBuffer, length);

$IF serverVfs OR PostOffice
			ELSE IF request = ddChangeUserContext 
				THEN error = FsChangeUserContext (pBuffer, length);
$ENDIF

			ELSE IF request > ddFlush THEN error = eNotSupport;

			ELSE DO CASE (request - ddGetStatus);
					
		    	error = FsGetStatus (sConnCB, pBuffer, length);

				error = FsOpen (sConnCB, numBuf);

				error = FsClose (sConnCB);

				IF vfsConnCB.objectMode <> 0 
				  	THEN error = FsDirRead (sConnCB, pBuffer, @pl.length);
					ELSE error = FsRead    (sConnCB, pBuffer, @pl.length);

				error = FsWrite (sConnCB, pBuffer, length);

				IF vfsConnCB.objectMode <> 0 
					THEN error = FsDirSeek (sConnCB, mode, pl.position);
					ELSE error = FsSeek    (sConnCB, mode, pl.position);

				error = FsTruncate (sConnCB);

				;	/* Attach */

    			error = FsDeleteOrDetach (ddDetach, sConnCB);

				error = FsRename (sConnCB, pBuffer);

    			error = FsDeleteOrDetach (ddDelete, sConnCB);

				DO;	/* Read Descriptor */
$IF Debugging
				IF (DebugMask AND Dbits_Fs) <> 0 
			      THEN CALL ConLineOut (@('ReadDescriptor: '), 16);
$ENDIF
				pl.length = maxDescLen - 2;
				error = RemoteRead (DOUBLE (ddReadDesc), sConnCB, 
                        						pBuffer,
										@pl.length);
$IF Debugging
				IF (DebugMask AND Dbits_Fs) <> 0 THEN 
					DO;
					CALL ConLineOut (@('ReadDescriptor Complete'), 23);
					CALL HexOut (error);
					CALL NewLine;
					END;
$ENDIF
				END;

				DO;	/* writeDescriptor */
$IF Debugging
				IF (DebugMask AND Dbits_Fs) <> 0 
			      THEN CALL ConLineOut (@('WriteDescriptor: '), 17);
$ENDIF
				error = RemoteWrite (DOUBLE (ddWriteDesc),sConnCB,
										pBuffer,
										maxDescLen - 2);
$IF Debugging
				IF (DebugMask AND Dbits_Fs) <> 0 THEN 
					DO;
					CALL ConLineOut (@('WriteDescriptor Complete'), 24);
					CALL HexOut (error);
					CALL NewLine;
					END;
$ENDIF
				END;

				DO;	/* FsFlushAllBuffers */
				IF (error := LocalFlush (sConnCB)) = 0 THEN
					DO;
$IF Debugging
					IF (DebugMask AND Dbits_Fs) <> 0 THEN 
						DO;
						CALL ConLineOut (@('Flush'), 5);
						CALL HexOut (connID);
						CALL NewLine;
						END;
					error = RemoteGeneral (DOUBLE (ddFlush), sConnCB);
					IF (DebugMask AND Dbits_Fs) <> 0 THEN 
						DO;
						CALL ConLineOut (@('Flush Complete:'), 15);
						CALL HexOut (error);
						CALL NewLine;
						END;
$ELSE
					error = RemoteGeneral (DOUBLE (ddFlush), sConnCB);
$ENDIF
					END;
				END;	/* FsFlushAllBuffers */
				END;	/* case */
			END;	/* VFS Requests */

		IF (request <> ddDetach) AND (request <> ddDelete) 
			THEN CALL OsSignal (vfsConnCB.inUseSema, signalNormal, 
						0, @dummyError);

		END;	

$IF Debugging
	IF (debugMask AND Dbits_DetailedFs) <> 0 THEN
		DO;
		DCL msg CHarStr ('Request Complete req/connID/error/dummyError =');
		CALL ConLineout (@msg, size (msg));
		CALL Hexout (request);
		CALL Hexout (connID);
		CALL Hexout (error);
		CALL Hexout (dummyError);
		CALL newline;
		END;
$ENDIF
END EntryPoint; /* OsRemoteFileSystem */


