DCL cpMachine		LIT '0';	/* from MsCall.Ext.Inc */
MsGetMachineType: PROCEDURE BYTE EXTERNAL; END;
MsReplaceInterrupts: PROCEDURE EXTERNAL; END;
MsExitBackGround: PROCEDURE EXTERNAL; END;


	/* The following signature should match the
	*linkSignature defined in UserInterface1 */

DCL Signature (*) BYTE PUBLIC INITIAL 
$IF Phonelink
							(14,'GRiDPhoneLink',0);
$ELSE
							(13,'GRiDGRiDLink',0);
$ENDIF

$IF Debugging
DCL RamEntryPoint BYTE EXTERNAL;
$ENDIF

$EJECT
/*&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&
&	PlmStart
&
&	MsReplaceInterrupts
&	MsExitBackground
&
&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&*/

PlmStart: PROCEDURE CLEAN;
DCL (error, dummy) 	WORD;
DCL dummyPTr		PTR;

$IF Debugging
$IF Phonelink
DCL VersionMsg CharStr	(ClearScreenSeq, 
					'MsDos Phonelink Version 85.08.20 resident',cr,lf,dollar);
$ELSE
DCL VersionMsg CharStr	(ClearScreenSeq, 
					'MsDos GRiDLink Version 85.08.20 resident',cr,lf,dollar);
$ENDIF
	CALL MsLineOut (@VersionMsg);

	DO;	 
	DCL entryPointValue PTR;
	DCL bo STRUCTURE (offset WORD, base WORD) AT (@EntryPointValue);
	entryPointValue = @RamEntryPoint;
	CALL MsLineOut (@('Data Segment Entry Point is at $'));
	CALL ConHexOut (bo.base);
	CALL MsCharOut (':');
	CALL ConHexOut (bo.offset);
	CALL NewLine;
	entryPointValue = @EntryPoint;
	CALL MsLineOut (@('Code Segment Entry Point is at $'));
	CALL ConHexOut (bo.base);
	CALL MsCharOut (':');
	CALL ConHexOut (bo.offset);
	CALL NewLine;
	END;

$ENDIF

	CALL FigureOutSystem;
	CALL MsReplaceInterrupts;
	CALL MsExitBackground;

END PlmStart;


OsRegisterName: PROCEDURE (pName, token, mode, pError) CLEAN;
	DCL pName	PTR;
    DCL token 	DWORD;
    DCL mode 	BYTE;
	DCL pError	PTR;
	DCL error 	BASED pError	WORD;
	error = 0;
END OsRegisterName;

