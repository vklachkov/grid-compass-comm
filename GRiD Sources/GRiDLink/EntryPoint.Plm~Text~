DCL (Compass, Hornet, pc, pcAT) BOOLEAN PUBLIC INITIAL (TRUE, FALSE, FALSE, 
		FALSE);
/*&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&
&	FigureOutSystem
&
&	This routine will figure out what System it is running on and set the
&	global booleans: Hornet, pc & pcAT.
&	
&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&*/

$IF NOT MsDos
CpScreenInfo: PROCEDURE (pBuf) EXTERNAL;
  DCL pBuf      PTR;
  END;
$ENDIF

DCL twoDashes  LIT '2d2dh';
DCL pPartNumber POINTER INITIAL (0FDFD0h),
	partNumber	BASED pPartNumber (1) WORD;

FigureOutSystem: PROCEDURE REENTRANT;
$IF MsDos
	IF MsGetMachineType <> cpMachine THEN
		DO;
$ELSE
DCL screenInfo ScreenInfoType;
	CALL CpScreenInfo (@screenInfo);
	IF SELECTOR$OF (screenInfo.pScreen) <> 40h THEN 
		DO;
$ENDIF
		compass = FALSE;
		IF partNumber(6) = twoDashes THEN Hornet = TRUE;
		ELSE IF (FLAGS AND 8000h) <> 0 THEN pc = TRUE;
		ELSE pcAT = TRUE;
		END;
END FigureOutSystem;
$ENDIF
