$TITLE ('VFS/VIPC/DataLink Entry Point')
$COMPACT 
$OPTIMIZE(3) SET(EntryPoint) SET (pipeLinedRead)

EntryPoint: DO;

/*&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&
&
&	This is EntryPoint. It contains the
&	entry points for all call to VFS and VIPC.
&
&	All three layers Vfs, Vipc & data link:
&
&		ddSignOn, ddSignoff, 
&		ddInitialize, ddDeactivate.
&
&	MsDos (only) Interceptor Calls
&
&		ddAddVfsDevice, ddGetVfsDevice, ddSetServerName, ddGetServerName
&		ddGetPrinterAlias, ddSetPrinterAlias, ddRestoreInterrupts
&
&	VFS calls:
&
&		ddGetStatus, ddOpen, ddCLoase, ddRead, ddWrite, ddSeek,
&		ddTruncate, ddAttach, ddDetach, ddRename, ddDelete, ddReadDesc,
&		ddWriteDesc, ddFlush, ddSetStatus, ddChangeUserContext
&
&	VIPC calls:
&
&		ddSend, ddAttach with mode = ProcessConnectMode.
&		ddDetach, ddGetUserInfo, ddSetStatus, ddGetLinkStatus
&	
&	Dlc calls:
&	
&		ddReadDlcCounters
&
&	For Debugging
&	
&		ddSetDebugMask 
&
&	currently ddGetStatus and ddSetstatus are not implemented for VIPC.
&
&
&	The ddxxx constants are defined in Os.Device.Inc.
&	Some ddxxx constants are defined in VfsVipc.Constant.Inc
&	The modes are defined in Os.Constant.Inc~Text~
&
&	Author:	Rajendra Shah
&	Start Date:	12/13/82
&
&	Edit History: Refer to 'z GRiDLink & PhoneLink Bogeys~Database~'
&
&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&*/

$EJECT
$SAVE NOLIST
	/* My favourite Plm literals */

$INCLUDE (``Incs`Plm.Inc~Text~)
	
	/* Os constants, types and externals */

$INCLUDE (``OsIncs`Os.Error.Inc~Text~)
$INCLUDE (``OsIncs`Os.Constant.Inc~Text~)
$INCLUDE (``OsIncs`Os.Device.Inc~Text~)
$INCLUDE (``OsIncs`Os.Type.Inc~Text~)

	/* Constants and Types */

$INCLUDE (VfsVipc.Constant.Inc~Text~)
$INCLUDE (VfsVipcConnCB.Type.Inc~Text~)

	/* Externals */

