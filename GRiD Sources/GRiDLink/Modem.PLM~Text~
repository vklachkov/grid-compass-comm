  DCL ErrorPtr	   PTR;
END;

FreeString:PROCEDURE (StringPtrPtr) EXTERNAL;
  DCL StringPtrPtr   PTR;				/* to a pointer */
END;


ConPeekChar: PROCEDURE BYTE EXTERNAL; END;
ConKeyPressed: PROCEDURE BOOLEAN EXTERNAL; END;
ConHexIn: PROCEDURE WORD EXTERNAL; END;

PasInitMessage: PROCEDURE EXTERNAL; END;
PasFreeMessage :PROCEDURE EXTERNAL; END;

PasDisplayMessage: PROCEDURE (code) EXTERNAL;
	DCL code WORD;
	END;

$IF Debugging

DCL DebugMask WORD EXTERNAL;
$INCLUDE (``GRiDLInk`Debug.Inc~Text~)

$ELSE

ConLineOUt: PROCEDURE (pBuffer, length) EXTERNAL;
