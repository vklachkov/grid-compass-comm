/* Vipc Protocol Function Codes */

DCL	VIPC_Px_Msg					AS	'0',
	VIPC_Px_Connect				AS	'1',
	VIPC_Px_ConnectResponse		AS	'2',
	VIPC_Px_Disconnect			AS	'3',
	VIPC_Px_DisconnectResponse	AS	'4',
	VIPC_Px_Signon				AS	'19',
	VIPC_Px_SignonResponse		AS	'6',
	VIPC_Px_Signoff				AS	'7',
	VIPC_Px_Error				AS	'100';

/* Vipc Interface Function Codes */

DCL VIPC_Ix_Msg					AS	'0',
	VIPC_Ix_MsgArrived			AS	'0',

	VIPC_Ix_ConnectRequest		AS	'1',	/* Client Layer to VIPC */
	VIPC_Ix_ConnectConfirm		AS	'2',	/* response from VIPC */

	VIPC_Ix_ConnectArrived		AS	'3',	/* VIPC to client layer */
	VIPC_Ix_ConnectResponse		AS	'4',	/* response from Client layer */

	VIPC_Ix_DisconnectRequest	AS	'5',	/* Client Layer to VIPC */
	VIPC_Ix_DisConnectConfirm	AS	'6',	/* response from VIPC */

	VIPC_Ix_DisconnectArrived	AS	'7',	/* VIPC to client layer */
	VIPC_Ix_DisconnectResponse	AS	'8',	/* response from Client layer */

	VIPC_Ix_SignonRequest		AS	'9',	/* Client layer  to VIPC */
	VIPC_Ix_SignonResponse		AS	'10',	/* response from VIPC */

	VIPC_Ix_ValidateUser		AS	'11',	/* VIPC to Admin */
	VIPC_Ix_ValidateResponse	AS	'12',	/* Response from admin */

	VIPC_Ix_Error				AS	'100';
$EJ
/* Vipc Layer State Machine States */

DCL	VIPC_Lx_Initial				AS	'0',
	VIPC_Lx_SignonSent			AS	'1',
	VIPC_Lx_SignonRcvd			AS	'2',
	VIPC_Lx_Running				AS	'3',
	VIPC_Lx_AutoSignon			AS	'4',
	VIPC_Lx_Ready				AS	'5',
	VIPC_Lx_Idle				AS	'6';


/* Vipc Connection State Machine States */

DCL	VIPC_Cx_Disconnected		AS	'0',
	VIPC_Cx_ConnectSent			AS	'1',
	VIPC_Cx_ConnectRcvd			AS	'2',
	VIPC_Cx_Connected			AS	'3',
	VIPC_Cx_DisconnectSent		AS	'4',
	VIPC_Cx_DisconnectRcvd		AS	'5';


/* Vipc and DLC Interface events */

DCL
	DLC_Ex_Started				AS	'1',
    DLC_Ex_Disconnected			AS	'2',
	DLC_Ex_IdlePollTwitch		AS	'3',
	DLC_Ex_ActivityTimeOUt		AS	'4',
	DLC_Ex_FrameArrived			AS	'5',
	DLC_Ex_PrintDlcMsg			AS	'6';


$EJ
