$EJECT
/*&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&
&	DisconnectUnusedConnection
&
&	Try to fine a vipc connection which was created by vfs but has no files
&   open on it now.
&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&*/

DisconnectUnusedConnection: PROCEDURE REENTRANT;
	DCL i 				WORD;
	DCL vipcConnID		WORD,
	 	sVipcConnCB		SELECTOR	AT	(@vipcConnID),
		vipcConnCB		BASED		sVipcConnCB	VipcConnCBType;
	DCL error1			WORD;

	CALL GetBigVipcLock;
	DO i = 0 TO VipcConnections-1;
		vipcConnID = connectionList (i);
		IF (vipcConnCB.clientIsVfs) AND (vipcConnCB.vfsConnections = 0) THEN
			DO;
			CALL VfsResetVipcConnForDevice (vipcConnID);
			CALL ReleaseBigVipcLock;
			error1 = VipcDisconnect (sVipcConnCB);
			CALL OsFree (BUILD$PTR (sVipcConnCB,0), @error1);
$			IF Debugging
			IF error1 <> 0 THEN
				DO;
					DCL msg CharStr ('Error in OsFree:');
				CALL ConLineOut (@msg, size(msg));
				CALL HexOut (error1);
				CALL Newline;
				END;
$			ENDIF
			RETURN;
			END;
		END;

	/* Did not find any vipc connections on which no files are open */

	CALL ReleaseBigVipcLock;
END DisconnectUnusedConnection;
$ENDIF

$EJECT
/*&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&
&	VipcInternalSend:  used by Vfs
&
&	when called by VipcSend header is the VipcHeader.  Whenc called by vfs
&	the header is vipc + vfs header.
&
&	This routine fills in the following vipc header fields:
&
&		functionCode, localPathID, remotePathID, vipcDataDength.  
&
&	Rest of the fields must be filled in by the caller.
&
&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&*/

VipcInternalSend: PROCEDURE (vipcConnID, headerLen, pHeader, bufferLen, pBuffer) 
						WORD CLEAN;

	DCL vipcConnID			WORD,
		sVipcConnCB			SELECTOR AT (@vipcConnID),
		vipcConnCB			BASED sVipcConnCB			VipcConnCBType;

	DCL headerLen			WORD, 
		bufferLen			WORD;
	DCL pHeader				PTR,
		pBuffer				PTR;

	DCL error				WORD;

	DCL vipcMessageHeader	Based pHeader VipcMessageHeaderType;

	/* If vipc layer is not running then 
	cannot send message */

	IF vipcConnCB.connState <> VIPC_Cx_Connected 
		THEN RETURN (vipcConnCB.reasonForDisconnect);

$IF Debugging
	IF NOT validVipcCOnnection (vipcConnID) THEN
		DO;
		DCL msg CharStr ('Invalid VipcConnection:');
		CALL conlineout (@msg, size(msg));
		CALL Hexout (vipcConnID);
		CALL newline;
		RETURN (eBadConn);
		END;
$ENDIF

	/* Prepare the header and send the message */

	vipcMessageHeader.vipcFunctionCode = VIPC_Px_Msg;
	vipcMessageHeader.localPathID  = vipcConnID;
	vipcMessageHeader.remotePathID = vipcConnCB.remotePathID;
	vipcMessageHeader.vipcDataLength = bufferLen + headerLen 
										- SIZE (VipcMessageHeader);
	error = DlcWrite (
				headerLen, 
				pHeader,
				bufferLen,
				pBuffer,
				FALSE);			/* Asynchronous */

$IF Debugging
	IF VipcMsgMaskSet THEN 
		DO;
		IF error = 0 THEN
			DO;
			DCL msg CharStr ('    Msg Sent, CID/cl/nt/ln: ');
			CALL ConLineOut (@msg, size(msg));
			CALL HexOut (vipcConnID);
			CALL HexOut (vipcMessageHeader.class);
			CALL HexOut (vipcMessageHeader.note);
			CALL HexOut (vipcMessageHeader.vipcDataLength);
			CALL NewLine;
			END;
		ELSE
			DO;
			DCL msg CharStr ('    Error in Int Send:');
			CALL ConLineOut (@msg, size(msg));
			CALL Hexout (error);
			CALL newline;
			END;
		END;
$ENDIF

	RETURN (error);

END VipcInternalSend;



$EJECT
/*&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&
&	VipcSend:  
&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&*/

VipcSend: PROCEDURE (vipcConnID, class, note, pVipcUserMsg) WORD CLEAN;

	DCL vipcConnID			WORD,
		sVipcConnCB			SELECTOR AT (@vipcConnID),
		vipcConnCB			BASED sVipcConnCB			VipcConnCBType;

	DCL (class, note) 		WORD;

	DCL	pVipcUserMsg		PTR,
		VipcUserMsg			BASED pVipcUserMsg VipcIfMsgType;

	DCL vipcMessageHeader	VipcMessageHeaderType;
	DCL error				WORD;
	DCL error1				WORD;

		/* If vipc layer is not running 
		then cannot send message */

	IF vipcConnCB.connState <> VIPC_Cx_Connected 
		THEN RETURN (vipcConnCB.reasonForDisconnect);

$IF Debugging
	IF NOT validVipcCOnnection (vipcConnID) THEN
		DO;
		DCL msg CharStr ('Invalid VipcConnection:');
		CALL conlineout (@msg, size(msg));
		CALL Hexout (vipcConnID);
		CALL newline;
		RETURN (eBadConn);
		END;
$ENDIF

	/* Check buffer length */

	If VipcUserMsg.VipcDataLength > maxVipcMsgLength 
		THEN RETURN (eMessageTooLong);

		/* Prepare the header and send the message */

	vipcMessageHeader.vipcFunctionCode = VIPC_Px_Msg;
	vipcMessageHeader.localPathID  = vipcConnID;
	vipcMessageHeader.remotePathID = vipcConnCB.remotePathID;
	vipcMessageHeader.class = class;
	vipcMessageHeader.note = note;

	IF pVipcUserMsg = NULLPTR 
	   THEN vipcMessageHeader.vipcDataLength = 0;
	   ELSE vipcMessageHeader.vipcDataLength = vipcUserMsg.vipcDataLength;

	error = DlcWrite (SIZE (VipcMessageHeader),
					@VipcMessageHeader,
	 				VipcMessageHeader.VipcDataLength,
					@VipcUserMsg.DataArea,	
		             	/* this will be junk for null messages */
					TRUE);		/* Synchronous */

	IF error = 0 THEN IF VipcUserMsg.toBeFreed THEN
		DO;
		CALL OsFree (@vipcUserMsg, @error1);
$		IF Debugging
		IF error1 <> 0 THEN
			DO;
				DCL msg CharStr ('Error in OsFree:');
			CALL ConLineOut (@msg, size(msg));
			CALL HexOut (error1);
			CALL Newline;
			END;
$		ENDIF
		END;

$IF Debugging
	IF VipcMsgMaskSet THEN 
		DO;
		CALL ConLineOut (@('    Msg Sent, CID/cl/nt/ln: '), 28);
		CALL HexOut (vipcConnID);
		CALL HexOut (vipcUserMsg.class);
		CALL HexOut (vipcUserMsg.note);
		CALL HexOut (vipcUserMsg.vipcDataLength);
		CALL NewLine;
		END;
$ENDIF

	RETURN (error);
END VipcSend;



