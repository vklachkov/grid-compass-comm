$IF DataLink
VipcProcessDataLinkEvent: PROCEDURE (event, pFrame, errorCode) EXTERNAL;
	DCL event				WORD, 
		pFrame 				PTR,
		errorCode			WORD;
	END;

$ELSEIF EntryPoint OR vfs1 OR VFS3

VipcSend: PROCEDURE (vipcConnID, class, note, pVipcUserBuffer) WORD EXTERNAL;
	DCL vipcConnID 			WORD;
	DCL class				WORD;
	DCL note				WORD;
	DCL	pVipcUserBuffer		PTR;
	END;

VipcInitialize: PROCEDURE WORD EXTERNAL;  END;

VipcTerminate: PROCEDURE WORD EXTERNAL;  END;

$ENDIF

$IF EntryPoint OR Vfs3
VipcSignON: PROCEDURE (plength, pUserInfo, pDataLinkInfo) WORD EXTERNAL;
	DCL	pLength				PTR;
	DCL	pUserInfo			PTR;
	DCL pDataLinkInfo		PTR;
	END;

VipcSignOFF: PROCEDURE WORD EXTERNAL;  END;

VipcGetUserInfo: PROCEDURE (pLength, pBuffer) WORD EXTERNAL;
	DCL plength PTR;
	DCL pBuffer PTR;
	END;

VipcGetLinkStatus: PROCEDURE (pLength, pBuffer) WORD EXTERNAL;
	DCL plength PTR;
	DCL pBuffer PTR;
	END;

VipcConnect: PROCEDURE (sVipcConnCB, pPathName) WORD EXTERNAL;
	DCL sVipcConnCB 		SELECTOR;
	DCL	pPathName			PTR;
	END;

VipcDisConnect: PROCEDURE (sVipcConnCB) WORD EXTERNAL;
	DCL sVipcConnCB 			SELECTOR;
	END;

VipcSetStatus: PROCEDURE (sConnCB, pBuffer, len) WORD EXTERNAL;
	DCL sConnCB	SELECTOR;
	DCL pBuffer	PTR;
	DCL len		WORD;
	END;

$ENDIF

$IF Vfs1 OR Vfs2 OR Vfs3
GetBigVipcLock: PROCEDURE EXTERNAL; END;

ReleaseBigVipcLock: PROCEDURE EXTERNAL; END;

