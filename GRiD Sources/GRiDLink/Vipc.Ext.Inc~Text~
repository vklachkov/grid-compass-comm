*/
VipcFreeReceiveBuffer: PROCEDURE EXTERNAL; END;

VipcInternalSend: PROCEDURE (vipcConnID, headerLen, pHeader, bufferLen, pBuffer)
						WORD EXTERNAL;

	DCL vipcConnID 			WORD;
	DCL headerLen			WORD,
		bufferLen	 		WORD;
	DCL pHeader				PTR,
		pBuffer				PTR;
	END;

HowIsVipc: PROCEDURE (vipcConnID) WORD EXTERNAL; 
	DCL vipcConnID 	WORD;
	END;

VipcReleaseResources: PROCEDURE (vipcConnID) EXTERNAL;
	DCL vipcConnID 		WORD;
	END;

VipcEnableActivityTimeOut: PROCEDURE EXTERNAL; END;

VipcDisableActivityTimeOut: PROCEDURE EXTERNAL; END;
$ENDIF

