/*&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&
*				State Transition Tables:
*
*	The transition tables for each state is an array of 3-tuples.
*	Each 3-tuple contains the following:
*
*			Event						BYTE
*			NextState					BYTE
*			Address of Action Procedure WORD
*
*	The table is terminated by a sentinel value of 0.
*
**&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&*/


DCL TransitionTblEntry LIT 'STRUCTURE (
					event				BYTE,
					nextState			BYTE,
					actionProcedure		WORD)';


/*&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&
