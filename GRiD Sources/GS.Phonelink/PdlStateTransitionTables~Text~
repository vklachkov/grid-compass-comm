PdlExUserTimeout,			nsc,				.PdlAcFreeCB,
PdlExResponseTimeOut,		nsc,				.PdlAcFreeCB,
PdlExPollTimeOut,			nsc,				.PdlAcFreeCB,
PdlExRcvdRfc,				nsc,				.PdlAcQueueReceive,
